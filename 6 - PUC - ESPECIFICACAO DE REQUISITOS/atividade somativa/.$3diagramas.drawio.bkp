        <mxCell id="kxPqtWrJ4l-z5bmPs-jO-3" value="REQUISITOS NÃO FUNCIONAIS" style="swimlane;whiteSpace=wrap;html=1;fontFamily=Verdana;fontSize=14;labelBackgroundColor=none;fillColor=#dae8fc;gradientColor=#7ea6e0;strokeColor=#6c8ebf;startSize=30;" vertex="1" parent="1">
