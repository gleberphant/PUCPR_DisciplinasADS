        <mxCell id="kxPqtWrJ4l-z5bmPs-jO-2" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;* funcionar 24 horas por dia,&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;* interface web e mobile.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 150%;&quot;&gt;* integração com sistemas academico e financeiro&lt;br&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;* processo mais rápido, simples e intuitivo,&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;* melhorar a experiência dos novos usuário&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212)); color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;* implementar esse novo sistema até novembro&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Verdana;fontSize=12;fontColor=default;labelBackgroundColor=default;strokeColor=none;align=left;" parent="kxPqtWrJ4l-z5bmPs-jO-3" vertex="1">
          <mxGeometry x="10" y="40" width="317.5" height="110" as="geometry" />
        </mxCell>
        <mxCell id="kxPqtWrJ4l-z5bmPs-jO-13" value="INFORMAÇÕES DO PROJETO" style="swimlane;whiteSpace=wrap;html=1;fontFamily=Verdana;fontSize=14;labelBackgroundColor=none;fillColor=#dae8fc;gradientColor=#7ea6e0;strokeColor=#6c8ebf;startSize=30;" parent="1" vertex="1">
          <mxGeometry x="405" y="650" width="350" height="160" as="geometry" />
        </mxCell>
        <mxCell id="kxPqtWrJ4l-z5bmPs-jO-14" value="&lt;div&gt;&lt;font&gt;&lt;span&gt;&lt;b&gt;Responsável&lt;/b&gt;: Handerson Gleber de Lima Cavalcanti&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;span&gt;&lt;b&gt;Prazo&lt;/b&gt;:&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;font&gt;implementar esse novo sistema até novembro 2026&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Verdana;fontSize=12;fontColor=default;labelBackgroundColor=default;strokeColor=none;align=left;" parent="kxPqtWrJ4l-z5bmPs-jO-13" vertex="1">
          <mxGeometry x="12.5" y="40" width="327.5" height="107.5" as="geometry" />
